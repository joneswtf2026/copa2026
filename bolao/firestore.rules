rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == "5aXDIjuTgfZnsmjhzzxYrbJMB8K2";
    }
    function isLoggedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Álbum de figurinhas (projeto antigo)
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Bolão — Config do site
    match /config/{doc} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Bolão — Usuários
    match /usuarios/{uid} {
      allow read: if isLoggedIn();
      allow write: if isOwner(uid) || isAdmin();
    }

    // Bolão — Palpites
    match /palpites/{uid}/jogos/{jogoId} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid);
      allow delete: if isAdmin();
    }

    // Bolão — Resultados
    match /resultados/{jogoId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Bolão — Pagamentos
    match /pagamentos/{pedidoId} {
      allow read: if isAdmin() || (isLoggedIn() && resource.data.uid == request.auth.uid);
      allow create: if isLoggedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Bolão — Jogos do mata-mata
    match /jogos_knockout/{jogoId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
  }
}
