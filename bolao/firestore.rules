rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == "5aXDIjuTgfZnsmjhzzxYrbJMB8K2";
    }
    function isLoggedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Album de figurinhas
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Bolao - Config
    match /config/{doc} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Bolao - Usuarios (leitura publica para o ranking)
    match /usuarios/{uid} {
      allow read: if isLoggedIn();
      allow write: if isOwner(uid) || isAdmin();
    }

    // Bolao - Palpites
    match /palpites/{uid}/jogos/{jogoId} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid);
      allow delete: if isAdmin();
    }

    // Bolao - Resultados
    match /resultados/{jogoId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Bolao - Pagamentos (simplificado)
    match /pagamentos/{pedidoId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // Bolao - Jogos knockout
    match /jogos_knockout/{jogoId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Bolao - Logs
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isLoggedIn();
    }
  }
}
